<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Se o arquivo ou diretório solicitado existe fisicamente, serve ele normalmente
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Caso contrário, redireciona tudo para index.html (SPA fallback)
  RewriteRule ^ index.html [QSA,L]
</IfModule>
